// https://aka.ms/vscode-remote/devcontainer.json
// https://github.com/microsoft/vscode-dev-containers/tree/master/containers/docker-existing-dockerfile
{
  "name": "Polynomial Masking DevContainer",
  "dockerFile": "Containerfile",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {
      "version": "latest",
      "ppa": "false"
    }
  },
  "containerEnv": {
    "VIRTUAL_ENV": "/workspace/discounted-poly-masking/.venv",
    "PATH": "/workspace/discounted-poly-masking/.venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
  },
  "postCreateCommand": "python3 -m venv /workspace/discounted-poly-masking/.venv --system-site-packages && /workspace/discounted-poly-masking/.venv/bin/pip install -r requirements.txt",
  "postStartCommand": "sh -lc 'for n in /dev/bus/usb/*/*; do udevadm info -q property -n \"$n\" 2>/dev/null | grep -q \"^ID_VENDOR_ID=2b3e$\" && sudo chmod a+rw \"$n\"; done || true'",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.makefile-tools",
        "ms-azuretools.vscode-docker",
        "ms-vscode.cpptools-extension-pack",
        "ms-python.python",
        "ms-toolsai.jupyter"
      ]
    }
  },
  "runArgs": [
    "--privileged",
    "-v",
    "/dev/bus/usb:/dev/bus/usb"
  ],
  "remoteUser": "vscode"
}