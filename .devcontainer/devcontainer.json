// https://aka.ms/vscode-remote/devcontainer.json
// https://github.com/microsoft/vscode-dev-containers/tree/master/containers/docker-existing-dockerfile
{
  "name": "Polynomial Masking DevContainer",
  "dockerFile": "Containerfile",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {
      "version": "latest",
      "ppa": "false"
    }
  },
  "containerEnv": {
    "VIRTUAL_ENV": "/home/vscode/.venvs/discounted-poly-masking"
  },
  "remoteEnv": {
    "PATH": "/home/vscode/.venvs/discounted-poly-masking/bin:${containerEnv:PATH}"
  },
  "postCreateCommand": "bash -lc 'python3 -m venv \"$VIRTUAL_ENV\" --system-site-packages && \"$VIRTUAL_ENV/bin/pip\" install -r \"${containerWorkspaceFolder}/requirements.txt\"'",
  "postStartCommand": "sh -lc 'lsusb -d 2b3e: | while read -r _ bus _ dev _; do dev=${dev%:}; sudo chmod a+rw \"/dev/bus/usb/$bus/$dev\"; done || true'",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.makefile-tools",
        "ms-azuretools.vscode-docker",
        "ms-vscode.cpptools-extension-pack",
        "ms-python.python",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/home/vscode/.venvs/discounted-poly-masking/bin/python"
      }
    }
  },
  "runArgs": [
    "--privileged",
    "-v",
    "/dev/bus/usb:/dev/bus/usb"
  ],
  "remoteUser": "vscode"
}